# Ignore node_modules for all subdirectories
node_modules/
**/node_modules/

# Ignore local build outputs
dist/
**/dist/
.next/
build/
**/build/

# Ignore environment files
.env
.env.local
.env.production
.env.example

# Ignore Git
.git
.gitignore

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
