NEXT_PUBLIC_APP_NAME=CohortVault
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
COHORTVAULT_API_WEB_ORIGIN=http://localhost:3000
COHORTVAULT_API_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cohortvault
COHORTVAULT_API_DATABASE_POOL_MIN_SIZE=1
COHORTVAULT_API_DATABASE_POOL_MAX_SIZE=6
COHORTVAULT_API_DATABASE_POOL_TIMEOUT_SECONDS=10.0
COHORTVAULT_API_STORAGE_BACKEND=local
COHORTVAULT_API_UPLOAD_DIR=data/uploads
COHORTVAULT_API_STORAGE_OBJECT_BUCKET=
COHORTVAULT_API_STORAGE_OBJECT_PREFIX=documents
# Required for real LLM calls. Get from https://platform.openai.com/api-keys
COHORTVAULT_API_OPENAI_API_KEY=
COHORTVAULT_API_OPENAI_CHAT_MODEL=gpt-4o-mini
COHORTVAULT_API_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
COHORTVAULT_API_OPENAI_EMBEDDING_DIMENSIONS=1536
COHORTVAULT_API_OPENAI_REQUEST_TIMEOUT_SECONDS=30.0
COHORTVAULT_API_OPENAI_MAX_RETRIES=2
COHORTVAULT_API_ATTESTATION_ADAPTER=mock-signed-receipt-v1
COHORTVAULT_API_RECEIPT_RUNTIME_ID=cv-runtime-dev-01
# Demo signing key for signed receipt v1. Override this outside local development.
COHORTVAULT_API_RECEIPT_SIGNING_KEY=cohortvault-dev-receipt-signing-key
COHORTVAULT_API_CAPABILITY_TTL_SECONDS=120
# Demo signing key for short-lived secret capabilities. Override this outside local development.
COHORTVAULT_API_CAPABILITY_SIGNING_KEY=cohortvault-dev-capability-key
COHORTVAULT_API_SESSION_COOKIE_NAME=cohortvault_actor
COHORTVAULT_API_COOKIE_SECURE=false
# Set to true when deploying behind HTTPS. Required for cookie security in production.
COHORTVAULT_API_WORKER_POLL_INTERVAL_SECONDS=1.0
COHORTVAULT_API_WORKER_MAX_ATTEMPTS=3
COHORTVAULT_API_WORKER_RETRY_BACKOFF_SECONDS=5.0
COHORTVAULT_API_RAG_CHUNK_SIZE=1500
COHORTVAULT_API_RAG_CHUNK_OVERLAP=200
COHORTVAULT_API_RAG_SNIPPET_LENGTH=600
COHORTVAULT_API_RETRIEVAL_CANDIDATE_LIMIT=12
COHORTVAULT_API_RETRIEVAL_MAX_SOURCES=3
COHORTVAULT_API_RETRIEVAL_LOG_PREVIEW_COUNT=3
# Length of source snippet shown to users and passed to the LLM in full mode.
# summary_only and redacted modes replace the snippet entirely.
# Tune based on your document types. 1500 chars works well for research papers
# and markdown notes with text-embedding-3-small.
# Optional for encrypted secret storage. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this key, secret values cannot be stored or injected.
# Secrets can still be registered as references and their revocation enforced.
COHORTVAULT_API_SECRET_ENCRYPTION_KEY=

OBJECT_STORAGE_BUCKET=cohortvault-documents
ANTHROPIC_API_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=
